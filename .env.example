POSTGRES_PASSWORD=your-secure-postgres-password
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long!!
ENCRYPTION_KEY=your-aes-encryption-key-for-api-keys!!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password

# Bybit Broker Program code (sent as Referer header on every Bybit API call).
# Defaults to Ty001081 if unset — change only if Bybit assigns a different code.
BYBIT_BROKER_ID=Ty001081
